<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<BorderPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" 
            fx:controller="com.SCL.ui.MainController"
            style="-fx-background-color: #1A1A2E;">

    <!-- 顶部栏 -->
    <top>
        <HBox style="-fx-background-color: #16213E; -fx-padding: 10 20;">
            <children>
                <!-- Logo -->
                <Label text="SCL" style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #E94560;"/>
                
                <!-- 空白 -->
                <Region HBox.hgrow="ALWAYS"/>
                
                <!-- 账户信息 -->
                <Label fx:id="accountLabel" text="未登录" style="-fx-font-size: 14px; -fx-text-fill: #B0B0B0;">
                    <padding>
                        <Insets right="20"/>
                    </padding>
                </Label>
                
                <!-- 最小化按钮 -->
                <Button text="─" style="-fx-background-color: transparent; -fx-text-fill: #B0B0B0; -fx-font-size: 20px; -fx-cursor: hand;"
                        onMouseClicked="#onMinimize"/>
                
                <!-- 关闭按钮 -->
                <Button text="✕" style="-fx-background-color: transparent; -fx-text-fill: #E94560; -fx-font-size: 20px; -fx-cursor: hand;"
                        onMouseClicked="#onClose">
                    <HBox.margin>
                        <Insets left="10"/>
                    </HBox.margin>
                </Button>
            </children>
        </HBox>
    </top>

    <!-- 左侧导航栏 -->
    <left>
        <VBox fx:id="sideNav" style="-fx-background-color: #16213E; -fx-pref-width: 200;">
            <padding>
                <Insets top="20"/>
            </padding>
            
            <!-- 导航项 -->
            <StackPane style="-fx-cursor: hand;" onMouseClicked="#onHomeClick">
                <HBox style="-fx-padding: 15 20; -fx-background-radius: 0;">
                    <Label text="🏠" style="-fx-font-size: 18px;"/>
                    <Label text="主页" style="-fx-font-size: 16px; -fx-text-fill: white; -fx-padding: 0 0 0 10;"/>
                </HBox>
            </StackPane>
            
            <StackPane style="-fx-cursor: hand;" onMouseClicked="#onVersionsClick">
                <HBox style="-fx-padding: 15 20;">
                    <Label text="🎮" style="-fx-font-size: 18px;"/>
                    <Label text="版本" style="-fx-font-size: 16px; -fx-text-fill: white; -fx-padding: 0 0 0 10;"/>
                </HBox>
            </StackPane>
            
            <StackPane style="-fx-cursor: hand;" onMouseClicked="#onAccountsClick">
                <HBox style="-fx-padding: 15 20;">
                    <Label text="👤" style="-fx-font-size: 18px;"/>
                    <Label text="账户" style="-fx-font-size: 16px; -fx-text-fill: white; -fx-padding: 0 0 0 10;"/>
                </HBox>
            </StackPane>
            
            <StackPane style="-fx-cursor: hand;" onMouseClicked="#onSettingsClick">
                <HBox style="-fx-padding: 15 20;">
                    <Label text="⚙️" style="-fx-font-size: 18px;"/>
                    <Label text="设置" style="-fx-font-size: 16px; -fx-text-fill: white; -fx-padding: 0 0 0 10;"/>
                </HBox>
            </StackPane>
            
            <Region VBox.vgrow="ALWAYS"/>
            
            <!-- 版本信息 -->
            <VBox style="-fx-padding: 20;">
                <Label text="SCL v1.0.0" style="-fx-font-size: 11px; -fx-text-fill: #666;"/>
            </VBox>
        </VBox>
    </left>

    <!-- 主内容区 -->
    <center>
        <StackPane fx:id="contentArea" style="-fx-background-color: #1A1A2E;"/>
    </center>

    <!-- 底部状态栏 -->
    <bottom>
        <HBox style="-fx-background-color: #16213E; -fx-padding: 8 20;">
            <children>
                <Label fx:id="statusLabel" text="就绪" style="-fx-font-size: 12px; -fx-text-fill: #B0B0B0;"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Label fx:id="memoryLabel" text="内存: 0MB" style="-fx-font-size: 12px; -fx-text-fill: #B0B0B0;">
                    <padding>
                        <Insets right="20"/>
                    </padding>
                </Label>
                <Label fx:id="versionLabel" text="v1.0.0" style="-fx-font-size: 12px; -fx-text-fill: #666;"/>
            </children>
        </HBox>
    </bottom>

</BorderPane>
