1000 DIALOGEX 0, 0, 900, 580
STYLE DS_SETFONT | DS_3DLOOK | DS_CENTER | WS_MINIMIZEBOX | WS_MAXIMIZEBOX | WS_VISIBLE | WS_CAPTION | WS_SYSMENU | WS_SIZEBOX
CAPTION "SCL - Minecraft启动器"
FONT 9, "Microsoft YaHei UI", 0, 0, 0
{
    // Logo区域
    LTEXT "SCL", 5001, 20, 10, 300, 40, SS_LEFT | WS_VISIBLE
    LTEXT "Minecraft启动器", 5002, 20, 45, 200, 20, SS_LEFT | WS_VISIBLE

    // 左侧面板 - 账户
    GROUPBOX "账户管理", 4000, 20, 80, 250, 200, WS_VISIBLE
    LISTBOX 4001, 30, 100, 230, 150, WS_VISIBLE | WS_BORDER | WS_VSCROLL | LBS_NOTIFY
    LTEXT "用户名:", -1, 30, 260, 60, 15, SS_LEFT | WS_VISIBLE
    EDITTEXT ID_EDIT_USERNAME, 30, 275, 150, 25, WS_VISIBLE | WS_BORDER | ES_AUTOHSCROLL
    PUSHBUTTON "添加离线账户", ID_BTN_LOGIN, 185, 275, 75, 25, WS_VISIBLE | BS_PUSHBUTTON

    // 中间面板 - 版本
    GROUPBOX "游戏版本", 5000, 290, 80, 400, 400, WS_VISIBLE
    LISTBOX ID_LIST_VERSIONS, 300, 100, 380, 350, WS_VISIBLE | WS_BORDER | WS_VSCROLL | LBS_NOTIFY
    PUSHBUTTON "刷新列表", ID_BTN_REFRESH, 300, 460, 90, 25, WS_VISIBLE | BS_PUSHBUTTON
    PUSHBUTTON "下载版本", ID_BTN_DOWNLOAD, 400, 460, 90, 25, WS_VISIBLE | BS_PUSHBUTTON
    PUSHBUTTON "启动游戏", ID_BTN_PLAY, 500, 460, 90, 25, WS_VISIBLE | BS_PUSHBUTTON
    PUSHBUTTON "设置", ID_BTN_SETTINGS, 600, 460, 80, 25, WS_VISIBLE | BS_PUSHBUTTON

    // 右侧面板 - 信息
    GROUPBOX "快速信息", 6000, 710, 80, 170, 200, WS_VISIBLE
    LTEXT "版本: 1.0.0", 6001, 720, 100, 150, 15, SS_LEFT | WS_VISIBLE
    LTEXT "作者: SCL", 6002, 720, 120, 150, 15, SS_LEFT | WS_VISIBLE
    LTEXT "镜像: BMCLAPI", 6003, 720, 140, 150, 15, SS_LEFT | WS_VISIBLE
    LTEXT "游戏目录:", 6004, 720, 165, 150, 15, SS_LEFT | WS_VISIBLE
    LTEXT "%APPDATA%\\.minecraft", 6005, 720, 180, 150, 40, SS_LEFT | WS_VISIBLE | SS_WORDELLIPSIS

    // 底部状态栏
    LTEXT "就绪", ID_STATIC_STATUS, 20, 530, 700, 20, SS_LEFT | WS_VISIBLE
    PUSHBUTTON "赞助我们", 7000, 780, 527, 90, 25, WS_VISIBLE | BS_PUSHBUTTON | BS_FLAT

    // 进度条
    CONTROL "", ID_PROGRESS, "msctls_progress32", WS_BORDER, 20, 555, 850, 15
}
