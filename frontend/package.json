{
  "name": "scl-launcher",
  "productName": "SCL Launcher",
  "version": "1.0.0",
  "description": "SCL Minecraft Launcher - A modern Minecraft launcher",
  "author": {
    "name": "SCL Team"
  },
  "main": "package.json",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "electron:build": "vite build && node scripts/build-electron.js && electron-builder --projectDir dist --win --dir",
    "electron:dist": "vite build && node scripts/build-electron.js && electron-builder --projectDir dist --win",
    "electron:rebuild": "electron-builder --projectDir dist --win --dir"
  },
  "dependencies": {
    "i18next": "^26.0.3",
    "lucide-react": "^1.7.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-i18next": "^17.0.2",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/node": "^24.12.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "autoprefixer": "^10.4.27",
    "electron": "41.1.1",
    "electron-builder": "^26.8.1",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "postcss": "^8.5.8",
    "tailwindcss": "^3.4.19",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.57.0",
    "vite": "^8.0.1"
  },
  "build": {
    "appId": "com.scl.launcher",
    "productName": "SCL Launcher",
    "directories": {
      "output": "../release"
    },
    "files": [
      "package.json"
    ],
    "extraResources": [
      {
        "from": "dist/start-backend.bat",
        "to": "start-backend.bat"
      }
    ],
    "asar": false,
    "win": {
      "target": [
        {
          "target": "zip",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "portable": {
      "artifactName": "${productName}-${version}-portable.exe"
    }
  }
}
