1 DIALOGEX 0, 0, 900, 620
STYLE DS_SETFONT | DS_MODALFRAME | WS_VISIBLE | WS_CAPTION
CAPTION "SCL - Minecraft Launcher"
FONT 9, "Segoe UI"
{
    GROUPBOX "Accounts", -1, 10, 80, 250, 200, WS_CHILD | WS_VISIBLE
    LISTBOX ID_LIST, 20, 100, 230, 160, WS_CHILD | WS_VISIBLE | WS_BORDER | WS_VSCROLL | LBS_NOTIFY
    LTEXT "Name:", -1, 20, 290, 50, 15
    EDITTEXT ID_EDIT, 20, 305, 150, 25, WS_CHILD | WS_VISIBLE | WS_BORDER
    PUSHBUTTON "Add", ID_BTN1, 180, 300, 70, 30, WS_CHILD | WS_VISIBLE | BS_PUSHBUTTON
    GROUPBOX "Versions", -1, 280, 80, 410, 400, WS_CHILD | WS_VISIBLE
    LISTBOX ID_LIST, 300, 100, 370, 360, WS_CHILD | WS_VISIBLE | WS_BORDER | WS_VSCROLL | LBS_NOTIFY
    PUSHBUTTON "Refresh", ID_BTN2, 300, 500, 100, 30, WS_CHILD | WS_VISIBLE | BS_PUSHBUTTON
    PUSHBUTTON "Download", ID_BTN3, 420, 500, 100, 30, WS_CHILD | WS_VISIBLE | BS_PUSHBUTTON
    PUSHBUTTON "Play", ID_BTN3, 540, 500, 100, 30, WS_CHILD | WS_VISIBLE | BS_DEFPUSHBUTTON | BS_PUSHBUTTON
    LTEXT "Ready", ID_STATUS, 20, 550, 400, 20, WS_CHILD | WS_VISIBLE | SS_LEFT
    LTEXT "v1.0.0", -1, 780, 550, 100, 20, WS_CHILD | WS_VISIBLE
}
